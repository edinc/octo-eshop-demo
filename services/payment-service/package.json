{
  "name": "@octo-eshop/payment-service",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --reporter=verbose --reporter=json --outputFile.json=../../.artifacts/tests/payment-service/results.json --coverage --coverage.provider=v8 --coverage.reporter=json --coverage.reportsDirectory=../../.artifacts/tests/payment-service/coverage",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@octo-eshop/types": "*",
    "@octo-eshop/utils": "*",
    "express": "^4.21.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "^2.1.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
