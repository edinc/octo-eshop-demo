{
  "name": "Octo E-Shop",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "VARIANT": "20"
    }
  },
  "runArgs": ["--cap-add=NET_ADMIN", "--device=/dev/net/tun"],
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "helm": "latest",
      "kubectl": "latest",
      "minikube": "none"
    },
    "ghcr.io/devcontainers/features/terraform:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/azure-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "typescript.tsdk": "node_modules/typescript/lib",
        "typescript.enablePromptUseWorkspaceTsdk": true,
        "[typescript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[typescriptreact]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[json]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[jsonc]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "eslint.workingDirectories": [{ "pattern": "services/*" }, { "pattern": "shared/*" }],
        "files.eol": "\n",
        "prisma.showPrismaDataPlatformNotification": false,
        "pgsql.serverGroups": [
          {
            "id": "octoeshop-dev",
            "name": "Octo E-Shop Dev (via VPN)",
            "color": "#0078D4",
            "description": "Dev PostgreSQL Flexible Servers. Reachable only when the OpenVPN P2S tunnel is up (see docs/dev-codespaces-openvpn.md). Password is prompted on first connect."
          }
        ],
        "pgsql.connections": [
          {
            "id": "octoeshop-dev-user-db",
            "groupId": "octoeshop-dev",
            "profileName": "user-db (dev)",
            "server": "octoeshop-dev-user-db-qyqw.postgres.database.azure.com",
            "port": "5432",
            "database": "userdb",
            "user": "pgadmin",
            "authenticationType": "SqlLogin",
            "emptyPasswordInput": true,
            "sslmode": "require"
          },
          {
            "id": "octoeshop-dev-product-db",
            "groupId": "octoeshop-dev",
            "profileName": "product-db (dev)",
            "server": "octoeshop-dev-product-db-qyqw.postgres.database.azure.com",
            "port": "5432",
            "database": "productdb",
            "user": "pgadmin",
            "authenticationType": "SqlLogin",
            "emptyPasswordInput": true,
            "sslmode": "require"
          },
          {
            "id": "octoeshop-dev-order-db",
            "groupId": "octoeshop-dev",
            "profileName": "order-db (dev)",
            "server": "octoeshop-dev-order-db-qyqw.postgres.database.azure.com",
            "port": "5432",
            "database": "orderdb",
            "user": "pgadmin",
            "authenticationType": "SqlLogin",
            "emptyPasswordInput": true,
            "sslmode": "require"
          }
        ]
      },
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "dsznajder.es7-react-js-snippets",
        "bradlc.vscode-tailwindcss",
        "Prisma.prisma",
        "ms-azuretools.vscode-docker",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "hashicorp.terraform",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "GitHub.vscode-github-actions",
        "GitHub.vscode-pull-request-github",
        "humao.rest-client",
        "editorconfig.editorconfig",
        "mikestead.dotenv",
        "redhat.vscode-yaml",
        "ms-azuretools.vscode-azureresourcegroups",
        "ms-ossdata.vscode-pgsql"
      ]
    }
  },
  "forwardPorts": [3000, 3001, 3002, 3003, 3004, 3005, 8080],
  "portsAttributes": {
    "3000": { "label": "Frontend", "onAutoForward": "notify" },
    "3001": { "label": "User Service", "onAutoForward": "silent" },
    "3002": { "label": "Product Service", "onAutoForward": "silent" },
    "3003": { "label": "Cart Service", "onAutoForward": "silent" },
    "3004": { "label": "Order Service", "onAutoForward": "silent" },
    "3005": { "label": "Payment Service", "onAutoForward": "silent" },
    "8080": { "label": "API Gateway (Kong)", "onAutoForward": "notify" }
  },
  "postCreateCommand": "npm install && npx husky",
  "postStartCommand": "bash ./.devcontainer/postcreate/install-dev-tools.sh",
  "remoteUser": "node"
}
