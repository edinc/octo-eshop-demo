{
  "name": "Octo E-Shop",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "helm": "latest",
      "kubectl": "latest",
      "minikube": "none"
    },
    "ghcr.io/devcontainers/features/terraform:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/azure-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "typescript.tsdk": "node_modules/typescript/lib",
        "typescript.enablePromptUseWorkspaceTsdk": true,
        "[typescript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[typescriptreact]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[json]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[jsonc]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "eslint.workingDirectories": [{ "pattern": "services/*" }, { "pattern": "shared/*" }],
        "files.eol": "\n",
        "prisma.showPrismaDataPlatformNotification": false
      },
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "dsznajder.es7-react-js-snippets",
        "bradlc.vscode-tailwindcss",
        "Prisma.prisma",
        "ms-azuretools.vscode-docker",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "hashicorp.terraform",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "GitHub.vscode-github-actions",
        "GitHub.vscode-pull-request-github",
        "humao.rest-client",
        "editorconfig.editorconfig",
        "mikestead.dotenv",
        "redhat.vscode-yaml",
        "ms-azuretools.vscode-azureresourcegroups"
      ]
    }
  },
  "forwardPorts": [3000, 3001, 3002, 3003, 3004, 3005, 8080],
  "portsAttributes": {
    "3000": { "label": "Frontend", "onAutoForward": "notify" },
    "3001": { "label": "User Service", "onAutoForward": "silent" },
    "3002": { "label": "Product Service", "onAutoForward": "silent" },
    "3003": { "label": "Cart Service", "onAutoForward": "silent" },
    "3004": { "label": "Order Service", "onAutoForward": "silent" },
    "3005": { "label": "Payment Service", "onAutoForward": "silent" },
    "8080": { "label": "API Gateway (Kong)", "onAutoForward": "notify" }
  },
  "postCreateCommand": "npm install && npx husky",
  "postStartCommand": "echo '✅ Octo E-Shop devcontainer ready. Start databases with: docker-compose up -d'",
  "remoteUser": "node"
}
